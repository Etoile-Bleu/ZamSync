# Normalize line endings: LF in repo, native on checkout
* text=auto eol=lf

# Windows scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell scripts always LF
*.sh text eol=lf

# Binary files -- no line ending conversion
*.wasm binary
*.png  binary
*.jpg  binary
*.ico  binary
